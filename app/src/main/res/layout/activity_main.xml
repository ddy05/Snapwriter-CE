<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <LinearLayout
        android:id="@+id/titleBar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#2f2f35"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Added Menu Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFiles"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:text="𖠿"
            android:enabled="false"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:padding="0dp"
            android:gravity="center"
            app:backgroundTint="#7075ff"
            app:cornerRadius="12dp"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvCurrentFile"
            android:layout_width="312dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="@font/font_instrument_sans"
            android:paddingEnd="8dp"
            android:singleLine="true"
            android:text="wow.html"
            android:textColor="#fff"
            android:textSize="14sp"
            android:textStyle="normal" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/menuBtn"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:enabled="true"
            android:gravity="center"
            android:padding="0dp"
            android:text="☰"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            app:backgroundTint="@color/menu_button_tint"
            app:cornerRadius="12dp" />

    </LinearLayout>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#000"/>
    <LinearLayout
        android:id="@+id/tabBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="6dp"
        android:background="#2f2f35"
        android:gravity="center_vertical">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/materialButton"
            android:layout_width="100dp"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:layout_weight="1"
            android:backgroundTint="#7075ff"
            android:textColor="@color/white"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:layout_width="105dp"
            android:layout_height="30dp"
            android:layout_marginLeft="8dp"
            android:backgroundTint="#505063"
            android:textColor="@color/white"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Remainder of your layout remains unchanged -->


    <LinearLayout
        android:id="@+id/containerPanel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#2f2f35"
        android:padding="6dp">

        <LinearLayout
            android:id="@+id/viewSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:background="@drawable/bg_view_settings_panel">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReadOnly"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_instrument_sans"
                android:text="View Mode"
                android:backgroundTint="#7075ff" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWrap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_instrument_sans"
                android:text="@string/toggle_wrap"
                android:backgroundTint="#7075ff" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLines"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/font_instrument_sans"
                android:text="@string/toggle_lines"
                android:backgroundTint="#7075ff" />
        </LinearLayout>

        <ddy.snapwriter.ui.editor.CodeEditor
            android:id="@+id/codeEditor"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="top|start"
            android:includeFontPadding="false"
            android:textSize="14sp"
            android:padding="8dp"
            android:scrollbars="vertical|horizontal" />

    </LinearLayout>

    <include
        android:id="@+id/editorToolbar"
        layout="@layout/view_editor_toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp" />

</LinearLayout>