<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style
        name="Theme.Snapwriter"
        parent="Theme.Material3.DayNight.NoActionBar">
        <item name="popupMenuStyle">@style/SnapwriterPopupMenu</item>
    </style>

    <style name="SnapwriterPopupMenu" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@drawable/bg_dialog_rounded</item>
        <item name="popupMenuBackground">@drawable/bg_dialog_rounded</item>
        <item name="android:elevation">0dp</item>
    </style>

    <style name="SnapwriterDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:windowBackground">@drawable/bg_dialog_rounded</item>

        <item name="colorSurface">#2f2f35</item>
        <item name="colorOnSurface">#FFFFFF</item>
        <item name="colorPrimary">#7075FF</item>

        <item name="materialAlertDialogTitleTextStyle">@style/NuclearDialogTitle</item>
        <item name="materialAlertDialogBodyTextStyle">@style/NuclearDialogBody</item>
    </style>

    <style name="SnapwriterDialog.DestructiveButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">#FF5555</item>
    </style>

    <style name="NuclearDialogTitle" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:fontFamily">@font/font_instrument_sans</item>
    </style>

    <style name="NuclearDialogBody" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:fontFamily">@font/font_instrument_sans</item>
    </style>
</resources>